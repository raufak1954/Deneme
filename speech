<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Speech to Text</title>
    <style>
        body { font-family: sans-serif; padding: 20px; text-align: center; }
        #result { border: 1px solid #ccc; padding: 10px; min-height: 100px; margin-top: 20px; border-radius: 8px; }
        button { padding: 15px 30px; font-size: 18px; cursor: pointer; background: #007AFF; color: white; border: none; border-radius: 10px; }
    </style>
</head>
<body>

    <h2>Konusmayi Metne Donustur</h2>
    <button id="start-btn">Mikrofonu Ac ve Konus</button>
    <div id="result">Metin burada gorunecek...</div>

    <script>
        const startBtn = document.getElementById('start-btn');
        const resultDiv = document.getElementById('result');
        
        // Support both webkit and standard
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

        if (SpeechRecognition) {
            const recognition = new SpeechRecognition();
            recognition.lang = 'tr-TR';
            recognition.interimResults = false;

            startBtn.onclick = () => {
                try {
                    recognition.start();
                    resultDiv.innerText = "Dinleniyor... Lutfen konusun.";
                } catch (e) {
                    resultDiv.innerText = "Hata: " + e.message;
                }
            };

            recognition.onresult = (event) => {
                const transcript = event.results[0][0].transcript;
                resultDiv.innerText = transcript;
            };

            recognition.onerror = (event) => {
                if(event.error === 'not-allowed') {
                    resultDiv.innerText = "Hata: Mikrofon izni verilmedi. Ayarlari kontrol edin.";
                } else {
                    resultDiv.innerText = "Hata olustu: " + event.error;
                }
            };
        } else {
            resultDiv.innerText = "Bu tarayici ses tanimayi desteklemiyor.";
        }
    </script>
</body>
</html>
